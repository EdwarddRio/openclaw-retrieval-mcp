# OpenClaw Context Engine JS - Environment Variables

# Server
HTTP_HOST=127.0.0.1
HTTP_PORT=8901

# External Services
CHROMA_URL=http://localhost:8000
EMBEDDING_URL=http://localhost:8902

# Project
PROJECT_ROOT=.
CONTEXT_ENGINE_RUNTIME_DIR=./runtime

# Embedding
CONTEXT_ENGINE_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# Memory
LOCALMEM_SESSION_MAX_AGE_DAYS=60
LOCALMEM_FACT_MAX_AGE_DAYS=180
LOCALMEM_AUTO_TRANSCRIPT_SYNC_ENABLED=true
LOCALMEM_AUTO_TRANSCRIPT_MAX_AGE_SECONDS=1800

# Debug
DEBUG_EXPORT_HISTORY_LIMIT=20
DEBUG_EXPORT_MAX_AGE_DAYS=3

# MCP
MCP_LOG_RETENTION_DAYS=3

# Benchmarks
BENCHMARKS_DIR=./runtime/benchmarks

# Cursor
CURSOR_PROJECTS_DIR=~/.cursor/projects
