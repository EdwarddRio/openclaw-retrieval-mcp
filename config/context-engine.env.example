# OpenClaw Context Engine 环境配置
# 复制此文件为 context-engine.env 并修改配置值

# ========== 核心路径 ==========

# 工作区根目录（LLMWiki、记忆文件等在此目录下）
PROJECT_ROOT=../workspace

# 运行时数据目录（SQLite 数据库、日志、基准测试数据等）
# 默认: ./runtime
# CONTEXT_ENGINE_RUNTIME_DIR=./runtime

# ========== HTTP 服务器 ==========

# HTTP 监听地址
HTTP_HOST=127.0.0.1

# HTTP 监听端口
HTTP_PORT=8901

# Unix Domain Socket 路径（为空时禁用）
HTTP_SOCKET_PATH=/tmp/openclaw-engine.sock

# API 认证密钥（为空时禁用认证，生产环境务必设置）
OPENCLAW_API_SECRET=

# ========== 记忆系统 ==========

# 自动来源每日写入上限
LOCALMEM_DAILY_WRITE_LIMIT=50

# 会话最大保留天数
LOCALMEM_SESSION_MAX_AGE_DAYS=60

# 事实记忆最大保留天数
LOCALMEM_FACT_MAX_AGE_DAYS=180

# ========== 调试 ==========

# 是否启用调试导出（1=启用，默认关闭）
# DEBUG_EXPORT_ENABLED=1

# 调试导出历史记录上限
# DEBUG_EXPORT_HISTORY_LIMIT=20

# 调试导出文件最大保留天数
# DEBUG_EXPORT_MAX_AGE_DAYS=3
